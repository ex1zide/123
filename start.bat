@echo off
chcp 65001 >nul 2>&1
title LegalHelp KZ — Automated Build Pipeline

echo.
echo ╔══════════════════════════════════════════════════════════════╗
echo ║        LegalHelp KZ — Enterprise Build Pipeline             ║
echo ║        Стандарт «Золотого ноутбука» • v2.0                  ║
echo ╚══════════════════════════════════════════════════════════════╝
echo.

:: ─────────────────────────────────
:: Шаг 1: Глубокая очистка кэша
:: ─────────────────────────────────
echo [1/5] 🧹 Очистка кэша (flutter clean)...
echo ────────────────────────────────────────
call flutter clean
if %ERRORLEVEL% NEQ 0 (
    echo ❌ ОШИБКА: flutter clean завершился с ошибкой!
    pause
    exit /b 1
)
echo ✅ Кэш успешно очищен.
echo.

:: ─────────────────────────────────
:: Шаг 2: Загрузка зависимостей
:: ─────────────────────────────────
echo [2/5] 📦 Загрузка зависимостей (flutter pub get)...
echo ────────────────────────────────────────
call flutter pub get
if %ERRORLEVEL% NEQ 0 (
    echo ❌ ОШИБКА: flutter pub get завершился с ошибкой!
    pause
    exit /b 1
)
echo ✅ Все зависимости загружены.
echo.

:: ─────────────────────────────────
:: Шаг 3: Генерация локализации
:: ─────────────────────────────────
echo [3/5] 🌍 Генерация локализации RU/KK (flutter gen-l10n)...
echo ────────────────────────────────────────
call flutter gen-l10n
if %ERRORLEVEL% NEQ 0 (
    echo ⚠️  ПРЕДУПРЕЖДЕНИЕ: flutter gen-l10n завершился с ошибкой. Проверьте ARB-файлы.
)
echo ✅ Локализация сгенерирована.
echo.

:: ─────────────────────────────────
:: Шаг 4: Кодогенерация Riverpod
:: ─────────────────────────────────
echo [4/5] ⚙️  Кодогенерация Riverpod (build_runner)...
echo ────────────────────────────────────────
call dart run build_runner build -d
if %ERRORLEVEL% NEQ 0 (
    echo ❌ ОШИБКА: build_runner завершился с ошибкой!
    pause
    exit /b 1
)
echo ✅ Все .g.dart файлы сгенерированы.
echo.

:: ─────────────────────────────────
:: Шаг 5: Запуск приложения
:: ─────────────────────────────────
echo [5/5] 🚀 Запуск LegalHelp KZ (flutter run)...
echo ════════════════════════════════════════
echo.
call flutter run

echo.
echo ╔══════════════════════════════════════════════════════════════╗
echo ║               Сессия завершена. До встречи!                 ║
echo ╚══════════════════════════════════════════════════════════════╝
pause
